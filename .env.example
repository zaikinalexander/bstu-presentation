APP_NAME="Презентация БГТУ им. В.Г. Шухова"
APP_ENV=local
APP_URL="http://127.0.0.1:8000"
APP_TIMEZONE="Europe/Moscow"

# mysql для продакшна:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bstu_presentation
# DB_USERNAME=bstu_user
# DB_PASSWORD=secret

# sqlite удобен для локальной разработки, если MySQL пока не поднят:
DB_DRIVER=sqlite
DB_DATABASE=storage/database.sqlite

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
